# URL of the Caddy admin API the UI manages
CADDY_ADMIN_URL=http://localhost:2019

# --- Authentication ---
# Set ADMIN_PASSWORD to require a password to use the UI. If left empty, the UI
# runs WITHOUT authentication (a warning is logged) — not recommended when exposed.
ADMIN_PASSWORD=

# Optional: secret used to sign session cookies. If unset, it is derived from
# ADMIN_PASSWORD (so changing the password logs everyone out).
SESSION_SECRET=

# Optional: session lifetime in hours (default 168 = 7 days)
SESSION_TTL_HOURS=168

# --- Update notifications (optional) ---
# Repo/branch checked to tell you when a newer version is available
GITHUB_REPO=bernardotwistag/CaddyUI
GITHUB_BRANCH=main
